---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;

// Generate FAQ Schema
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section class="faq-section">
  <h2 class="faq-title">คำถามที่พบบ่อย</h2>
  <div class="faq-list">
    {faqs.map((faq, index) => (
      <details class="faq-item" open={index === 0}>
        <summary class="faq-question">{faq.question}</summary>
        <div class="faq-answer">
          <p set:html={faq.answer} />
        </div>
      </details>
    ))}
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<style>
  .faq-section {
    margin-top: 2rem;
    padding: 2rem;
    background: #f9f9f9;
    border-radius: 0.5rem;
  }

  .faq-title {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: #333;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .faq-item {
    background: white;
    border: 1px solid #e0e0e0;
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .faq-question {
    padding: 1rem;
    cursor: pointer;
    font-weight: 600;
    color: #333;
    display: flex;
    align-items: center;
    justify-content: space-between;
    user-select: none;
    transition: background-color 0.2s;
  }

  .faq-question:hover {
    background-color: #f5f5f5;
  }

  .faq-question::after {
    content: '▼';
    font-size: 0.75rem;
    color: #0066cc;
    transition: transform 0.2s;
    margin-left: 1rem;
  }

  .faq-item[open] .faq-question::after {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 1rem;
    border-top: 1px solid #e0e0e0;
    color: #666;
    line-height: 1.6;
  }

  .faq-answer p {
    margin: 0;
  }

  .faq-answer p + p {
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .faq-section {
      padding: 1.5rem;
    }

    .faq-title {
      font-size: 1.25rem;
    }

    .faq-question {
      padding: 0.75rem;
      font-size: 0.95rem;
    }

    .faq-answer {
      padding: 0.75rem;
      font-size: 0.9rem;
    }
  }
</style>
